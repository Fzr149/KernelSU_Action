KERNEL_SOURCE=https://github.com/Fzr149/Xiaomi_Kernel_OpenSource
KERNEL_SOURCE_BRANCH=topaz-t-oss
KERNEL_CONFIG=vendor/topaz_GKI.config
KERNEL_IMAGE_NAME=Image
ARCH=arm64

# Clang - pakai AOSP default
USE_CUSTOM_CLANG=false
CLANG_VERSION=r450784e
CLANG_BRANCH=master-kernel-build-2022

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# KernelSU - terserah mau enable atau ngga
ENABLE_KERNELSU=false

# Sisanya biarkan default
